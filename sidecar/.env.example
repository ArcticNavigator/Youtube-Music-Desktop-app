# Supabase — sidecar data layer (Phase 2: first-login record + data rights).
# Copy this file to .env and fill in your own Supabase project's values.
# The anon key is publishable (Row Level Security is the real guard, not secrecy).
# Never put a service_role key here — it must only exist server-side, auto-injected
# into Supabase Edge Functions.
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
